{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "make TOOLCHAIN=/usr/bin/arm-none-eabi-",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}",
            }
        },
        {
            "label": "build & deploy",
            "type": "shell",
            // edit the path to your mounted Endless device 
            "command": "rm -f build/*.bin && make TOOLCHAIN=/usr/bin/arm-none-eabi- && cp build/*.bin /media/wojtek/ENDLESS/",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}",
            }
        }
    ]
}